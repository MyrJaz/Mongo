<%- include('../partials/header') %>

<a href="/users/<%= user._id %>" class="text-muted">Volver a <%= user.username %></a>
<h1>Editar usuario</h1>

<div class="card">
  <form method="POST" action="/users/<%= user._id %>/update">
    <div class="grid-2">
      <div class="form-group">
        <label>Username *</label>
        <input type="text" name="username" required value="<%= user.username %>" />
      </div>
      <div class="form-group">
        <label>Segmento</label>
        <select name="segment">
          <% segments.forEach(s => { %>
            <option value="<%= s %>" <%= user.segment === s ? 'selected' : '' %>><%= s %></option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="grid-2">
      <div class="form-group">
        <label>Email *</label>
        <input type="email" name="email" required value="<%= user.contact.email %>" />
      </div>
      <div class="form-group">
        <label>Telefono</label>
        <input type="text" name="phone" value="<%= user.contact.phone || '' %>" />
      </div>
    </div>
    <div class="grid-2">
      <div class="form-group">
        <label>Ciudad</label>
        <input type="text" name="city" value="<%= user.contact.city || '' %>" />
      </div>
      <div class="form-group">
        <label>Pais</label>
        <input type="text" name="country" value="<%= user.contact.country || '' %>" maxlength="2" />
      </div>
    </div>
    <div class="grid-2">
      <div class="form-group">
        <label>Edad</label>
        <input type="number" name="age" value="<%= user.demographics.age %>" min="1" max="120" />
      </div>
      <div class="form-group">
        <label>Genero</label>
        <select name="gender">
          <% ['M','F','Non-binary','Unknown'].forEach(g => { %>
            <option value="<%= g %>" <%= user.demographics.gender === g ? 'selected' : '' %>>
              <%= g === 'M' ? 'Masculino' : g === 'F' ? 'Femenino' : g %>
            </option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="actions">
      <button type="submit" class="btn btn-primary">Guardar cambios</button>
      <a href="/users/<%= user._id %>" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
