<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MovieStream DB</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, -apple-system, sans-serif; background: #0f0f13; color: #e2e2e2; min-height: 100vh; }
    a { color: #a78bfa; text-decoration: none; }
    a:hover { text-decoration: underline; }

    nav {
      background: #18181f;
      border-bottom: 1px solid #2d2d3a;
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      gap: 2rem;
    }
    nav .logo { font-size: 1.2rem; font-weight: 700; color: #a78bfa; }
    nav a { color: #ccc; font-size: 0.95rem; }
    nav a:hover { color: #fff; text-decoration: none; }

    .container { max-width: 1100px; margin: 0 auto; padding: 2rem; }

    h1 { font-size: 1.8rem; margin-bottom: 1.5rem; color: #fff; }
    h2 { font-size: 1.3rem; margin-bottom: 1rem; color: #ddd; }

    .card { background: #18181f; border: 1px solid #2d2d3a; border-radius: 10px; padding: 1.5rem; margin-bottom: 1rem; }

    .badge { display: inline-block; background: #2d2d3a; color: #a78bfa; border-radius: 4px; padding: 2px 8px; font-size: 0.75rem; margin: 2px; }
    .badge.green { background: #1a2e1a; color: #86efac; }
    .badge.blue { background: #1a1f2e; color: #93c5fd; }
    .badge.orange { background: #2e1f1a; color: #fdba74; }

    .btn { display: inline-block; padding: 0.5rem 1.2rem; border-radius: 6px; font-size: 0.9rem; cursor: pointer; border: none; font-family: inherit; }
    .btn-primary { background: #7c3aed; color: #fff; }
    .btn-primary:hover { background: #6d28d9; text-decoration: none; color: #fff; }
    .btn-secondary { background: #2d2d3a; color: #ccc; }
    .btn-secondary:hover { background: #3d3d4a; text-decoration: none; color: #fff; }
    .btn-danger { background: #7f1d1d; color: #fca5a5; }
    .btn-danger:hover { background: #991b1b; color: #fff; text-decoration: none; }
    .btn-sm { padding: 0.3rem 0.8rem; font-size: 0.8rem; }

    .form-group { margin-bottom: 1.2rem; }
    label { display: block; margin-bottom: 0.4rem; color: #aaa; font-size: 0.9rem; }
    input[type=text], input[type=number], input[type=email], textarea, select {
      width: 100%; background: #0f0f13; border: 1px solid #3d3d4a;
      color: #e2e2e2; padding: 0.6rem 0.8rem; border-radius: 6px;
      font-family: inherit; font-size: 0.95rem;
    }
    input:focus, textarea:focus, select:focus { outline: none; border-color: #7c3aed; }
    textarea { resize: vertical; min-height: 90px; }

    .genre-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.4rem; }
    .genre-check { display: none; }
    .genre-label { display: inline-block; padding: 4px 12px; border: 1px solid #3d3d4a; border-radius: 20px; cursor: pointer; font-size: 0.85rem; color: #aaa; }
    .genre-check:checked + .genre-label { background: #4c1d95; border-color: #7c3aed; color: #fff; }

    .search-bar { display: flex; gap: 0.8rem; margin-bottom: 1.5rem; flex-wrap: wrap; align-items: flex-end; }
    .search-bar input, .search-bar select { width: auto; flex: 1; min-width: 160px; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media (max-width: 640px) { .grid-2 { grid-template-columns: 1fr; } }

    .stat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem; }
    @media (max-width: 640px) { .stat-grid { grid-template-columns: 1fr; } }
    .stat-card { background: #18181f; border: 1px solid #2d2d3a; border-radius: 10px; padding: 1.5rem; text-align: center; }
    .stat-card .num { font-size: 2.5rem; font-weight: 700; color: #a78bfa; }
    .stat-card .label { color: #888; font-size: 0.9rem; margin-top: 0.3rem; }

    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; color: #888; font-size: 0.8rem; padding: 0.6rem 0.8rem; border-bottom: 1px solid #2d2d3a; }
    td { padding: 0.7rem 0.8rem; border-bottom: 1px solid #1e1e28; font-size: 0.9rem; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #1f1f2a; }

    .actions { display: flex; gap: 0.5rem; align-items: center; }
    .mt { margin-top: 1rem; }
    .text-muted { color: #666; font-size: 0.85rem; }
    .empty { text-align: center; color: #555; padding: 3rem 1rem; }
  </style>
</head>
<body>
  <nav>
    <span class="logo">MovieStream</span>
    <a href="/">Inicio</a>
    <a href="/movies">Peliculas</a>
    <a href="/users">Usuarios</a>
  </nav>
  <div class="container">
